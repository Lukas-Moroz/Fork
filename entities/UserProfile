{
  "name": "UserProfile",
  "type": "object",
  "properties": {
    "user_email": {
      "type": "string"
    },
    "display_name": {
      "type": "string"
    },
    "username": {
      "type": "string"
    },
    "bio": {
      "type": "string"
    },
    "location": {
      "type": "string"
    },
    "avatar": {
      "type": "string"
    },
    "cuisine_prefs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notifications_enabled": {
      "type": "boolean",
      "default": true
    },
    "privacy_mode": {
      "type": "string",
      "enum": [
        "public",
        "friends",
        "private"
      ],
      "default": "friends"
    }
  },
  "required": [
    "user_email"
  ]
}