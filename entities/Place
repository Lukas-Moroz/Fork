{
  "name": "Place",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Restaurant or place name"
    },
    "cuisine": {
      "type": "string",
      "description": "Cuisine type"
    },
    "platform": {
      "type": "string",
      "enum": [
        "instagram",
        "tiktok",
        "youtube",
        "x",
        "other"
      ],
      "default": "instagram"
    },
    "address": {
      "type": "string"
    },
    "coords": {
      "type": "array",
      "items": {
        "type": "number"
      },
      "description": "[lat, lng]"
    },
    "link": {
      "type": "string"
    },
    "image": {
      "type": "string"
    },
    "rating": {
      "type": "number"
    },
    "price_range": {
      "type": "string",
      "description": "$, $$, $$$, or $$$$"
    },
    "visited": {
      "type": "boolean",
      "default": false
    },
    "notes": {
      "type": "string",
      "default": ""
    },
    "reaction": {
      "type": "string"
    },
    "saved_by_name": {
      "type": "string"
    }
  },
  "required": [
    "name"
  ]
}